# ─────────────────────────────────────────────────────────────────────────────
# FASTAPI BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env for local development.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (same DB as the Node backend)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/student-task-tracker?retryWrites=true&w=majority

# JWT signing secret — must match the Node backend secret if migrating gradually
JWT_SECRET=replace_with_a_long_random_hex_string_at_least_32_chars

# Allowed frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:3000

# Server port
PORT=8000

# Environment
ENVIRONMENT=development

# Upload directory (relative to python-backend/)
UPLOAD_DIR=uploads
