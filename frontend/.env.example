# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND ENVIRONMENT VARIABLES
# These are baked into the JS bundle at build time by Vite.
# Set VITE_API_URL in the Vercel dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# Your deployed Render backend URL (no trailing slash)
# Leave empty in development — Vite proxy handles /api/* locally
VITE_API_URL=https://your-backend.onrender.com
