# Production — used by Vite at build time.
#
# When running behind Nginx (docker-compose), leave this empty so the
# browser uses the same origin and Nginx proxies /api/* → backend.
#
# For external deployments (Vercel + Render), set this to your backend URL:
#   VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=
