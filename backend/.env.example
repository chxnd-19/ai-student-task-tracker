# ── MongoDB ──────────────────────────────────────────────────────────────────
# Format: mongodb://<username>:<password>@<host>:<port>/<db_name>
# For Docker: Use mongodb:27017
MONGO_URI=mongodb://mongodb:27017/student-task-tracker
DB_NAME=student-task-tracker

# ── Authentication ────────────────────────────────────────────────────────────
# Minimum 32 character random string
JWT_SECRET=change_this_to_a_secure_random_string_at_least_32_chars_long

# ── Server Configuration ──────────────────────────────────────────────────────
# Options: development, production
ENVIRONMENT=production
PORT=8000
FRONTEND_URL=http://localhost
UPLOAD_DIR=uploads

# ── Alerting (Optional) ───────────────────────────────────────────────────────
# URL for POSTing JSON alerts (Discord/Slack webhooks, etc.)
ALERT_WEBHOOK_URL=
